# image/Containerfile
# Base image quay.io/podman/stable already provides:
#   - `podman` user at UID 1000 with subuid/subgid configured for rootless PiP
#   - /home/podman as that user's home
#   - rootless podman + fuse-overlayfs preinstalled
FROM quay.io/podman/stable:latest

ARG RUNNER_VERSION
ARG TARGETARCH

USER root
RUN dnf -y install \
        curl jq git tar gzip ca-certificates \
        libicu krb5-libs openssl-libs zlib && \
    dnf clean all

USER podman
WORKDIR /home/podman

RUN set -eu; \
    arch=${TARGETARCH:-amd64}; \
    case "$arch" in \
        amd64) rarch=x64 ;; \
        arm64) rarch=arm64 ;; \
        *) echo "unsupported arch $arch" >&2; exit 1 ;; \
    esac; \
    curl -fsSL -o runner.tgz \
      "https://github.com/actions/runner/releases/download/v${RUNNER_VERSION}/actions-runner-linux-${rarch}-${RUNNER_VERSION}.tar.gz"; \
    tar xzf runner.tgz && rm runner.tgz

COPY --chown=podman:podman entrypoint.sh /home/podman/entrypoint.sh
USER root
RUN chmod 0755 /home/podman/entrypoint.sh
USER podman

# Inner podman storage rooted at /cache/podman-storage so layer cache persists
# across jobs in the same (slot, repo). The host bind-mounts the per-(slot, repo)
# cache directory at /cache.
ENV CONTAINERS_STORAGE_CONF=/home/podman/.config/containers/storage.conf
RUN mkdir -p /home/podman/.config/containers && \
    printf '[storage]\ndriver = "overlay"\ngraphroot = "/cache/podman-storage"\nrunroot = "/tmp/podman-run"\n[storage.options.overlay]\nmount_program = "/usr/bin/fuse-overlayfs"\n' \
        > /home/podman/.config/containers/storage.conf

ENTRYPOINT ["/home/podman/entrypoint.sh"]
